<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Outgoing network connections: HTTP polling of mimoLive API on localhost:8989 -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Incoming network connections: embedded HTTP server on port 8990 -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Apple Events automation: NSRunningApplication.terminate() sends kAEQuitApplication
         to mimoLive; required for Hardened Runtime apps that send Apple Events to other apps -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Allow loading Sparkle.framework (signed with a different Team ID in dev builds) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
